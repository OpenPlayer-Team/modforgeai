<Window
    x:Class="WinUIMvvmApp.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinUIMvvmApp.ViewModels"
    xmlns:v="using:WinUIMvvmApp.Views"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:converters="using:WinUIMvvmApp"
    xmlns:cloud="using:WinUIMvvmApp.Cloud"
    xmlns:plugins="using:WinUIMvvmApp.Plugins"
    mc:Ignorable="d"
    Title="WinUI 3 File Explorer - MVVM"
    Width="1200"
    Height="700">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>

    <Window.Resources>
        <!-- Converter per visibilità da intero (zero) -->
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
        
        <!-- Converter per formattazione dimensioni -->
        <converters:BytesToStringConverter x:Key="BytesToStringConverter" />
        
        <!-- Converter per data -->
        <converters:DateTimeToStringConverter x:Key="DateTimeToStringConverter" />
        
        <!-- Converter per visibilità inversa -->
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        
        <!-- Converter per peso font -->
        <converters:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter" />
        
        <!-- Converter per stato split -->
        <converters:SplitOrientationConverter x:Key="SplitOrientationConverter" />
        
        <!-- Converter per testo orientamento -->
        <converters:OrientationTextConverter x:Key="OrientationTextConverter" />
        
        <!-- Converter per stato sincronizzazione -->
        <converters:SyncStatusConverter x:Key="SyncStatusConverter" />
        
        <!-- Converter per stato ricerca -->
        <converters:SearchStatusConverter x:Key="SearchStatusConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header con barra dei menu -->
        <Grid Grid.Row="0" Background="{ThemeResource SystemControlBackgroundAltHighBrush}" Padding="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Menu principale -->
            <MenuBar Grid.Column="0">
                <MenuBarItem Title="File">
                    <MenuFlyoutItem Text="Nuova Scheda" Icon="Add">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="T" Modifiers="Control" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Chiudi Scheda" Icon="Cancel">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="W" Modifiers="Control" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Esci" Icon="Cancel" Click="ExitMenuItem_Click" />
                </MenuBarItem>
                
                <!-- Menu Cloud -->
                <MenuBarItem Title="Cloud">
                    <MenuFlyoutItem Text="OneDrive" Tag="OneDriveMock" Click="CloudProvider_Click">
                        <MenuFlyoutItem.Icon>
                            <SymbolIcon Symbol="Cloud" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Google Drive" Tag="GoogleDriveMock" Click="CloudProvider_Click">
                        <MenuFlyoutItem.Icon>
                            <SymbolIcon Symbol="Cloud" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Aggiorna Cloud" Click="RefreshCloud_Click" Icon="Refresh" />
                    <MenuFlyoutItem Text="Disconnetti Cloud" Click="DisconnectCloud_Click" Icon="Cancel" />
                </MenuBarItem>
                
                <!-- Menu Plugins -->
                <MenuBarItem Title="Plugins">
                    <MenuFlyoutItem Text="Ricarica Plugins" Icon="Refresh" Click="ReloadPlugins_Click" />
                    <MenuFlyoutSeparator />
                    <!-- Comandi plugin dinamici -->
                    <MenuFlyoutSubItem x:Name="PluginsSubMenu" Text="Comandi Disponibili" Icon="Puzzle">
                        <MenuFlyoutSubItem.Items>
                            <MenuFlyoutItem x:Name="NoPluginsItem" Text="Nessun plugin caricato" IsEnabled="False" />
                        </MenuFlyoutSubItem.Items>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Info Plugins" Click="ShowPluginsInfo_Click" Icon="Help" />
                </MenuBarItem>
                
                <MenuBarItem Title="Visualizza">
                    <MenuFlyoutItem Text="Aggiorna" Icon="Refresh">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F5" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Cerca (Ctrl+F)" Icon="Find">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="F" Modifiers="Control" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Split Orizzontale" Icon="Split">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="H" Modifiers="Control" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Split Verticale" Icon="Split">
                        <MenuFlyoutItem.KeyboardAccelerators>
                            <KeyboardAccelerator Key="V" Modifiers="Control" />
                        </MenuFlyoutItem.KeyboardAccelerators>
                    </MenuFlyoutItem>
                </MenuBarItem>
                <MenuBarItem Title="Aiuto">
                    <MenuFlyoutItem Text="Informazioni" Icon="Help" />
                </MenuBarItem>
            </MenuBar>

            <!-- Pulsanti azioni rapide -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <Button Content="Nuova Scheda" 
                        Command="{x:Bind ViewModel.AddNewTabCommand, Mode=OneWay}"
                        CommandParameter="C:\"
                        ToolTipService.ToolTip="Nuova scheda (Ctrl+T)">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <SymbolIcon Symbol="Add" />
                                <TextBlock Text="Nuova Scheda" />
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Barra di ricerca -->
        <Border Grid.Row="1"
                Background="{ThemeResource SystemControlBackgroundAltMediumLowBrush}"
                Padding="8,4"
                Margin="0,0,0,4">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- TextBox per la query di ricerca -->
                <TextBox Grid.Column="0"
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Cerca file (almeno 2 caratteri)..."
                         MinWidth="200"
                         VerticalAlignment="Center">
                    <ToolTipService.ToolTip>
                        <ToolTip Content="Digita per cercare (debounce 500ms)" />
                    </ToolTipService.ToolTip>
                </TextBox>

                <!-- Pulsante Avvia/Ripeti Ricerca -->
                <Button Grid.Column="1"
                        Content="🔍"
                        Command="{x:Bind ViewModel.SearchAsyncCommand, Mode=OneWay}"
                        IsEnabled="{x:Bind ViewModel.SearchText.Length, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}"
                        ToolTipService.ToolTip="Avvia ricerca (Ctrl+F)"
                        Width="32" Height="32"
                        Padding="0" />

                <!-- Pulsante Annulla Ricerca -->
                <Button Grid.Column="2"
                        Content="✕"
                        Command="{x:Bind ViewModel.CancelSearchCommand, Mode=OneWay}"
                        IsEnabled="{x:Bind ViewModel.IsSearchActive, Mode=OneWay}"
                        ToolTipService.ToolTip="Annulla ricerca"
                        Width="32" Height="32"
                        Padding="0"
                        Background="{ThemeResource SystemControlBackgroundAltMediumBrush}" />

                <!-- Pulsante Pulisci Risultati -->
                <Button Grid.Column="3"
                        Content="🗑️"
                        Command="{x:Bind ViewModel.ClearSearchCommand, Mode=OneWay}"
                        IsEnabled="{x:Bind ViewModel.SearchResults.Count, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}"
                        ToolTipService.ToolTip="Pulisci risultati"
                        Width="32" Height="32"
                        Padding="0"
                        Background="Transparent" />
            </Grid>
        </Border>

        <!-- Barra di progresso ricerca -->
        <Border Grid.Row="1"
                Background="{ThemeResource SystemControlBackgroundAltMediumLowBrush}"
                Padding="8,0,8,4"
                Margin="0,0,0,4"
                IsVisible="{x:Bind ViewModel.IsSearchActive, Mode=OneWay}">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ProgressBar Grid.Column="0"
                             Value="{x:Bind ViewModel.SearchProgress, Mode=OneWay}"
                             Minimum="0"
                             Maximum="100"
                             IsIndeterminate="False"
                             Height="4" />

                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.SearchProgress, Mode=OneWay, StringFormat='{} {0}%'}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
            </Grid>
        </Border>

        <!-- Area TabView / Risultati Ricerca -->
        <Grid Grid.Row="2">
            <!-- TabView normale -->
            <controls:TabView x:Name="MainTabView"
                              ItemsSource="{x:Bind ViewModel.Tabs, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedTab, Mode=TwoWay}"
                              TabCloseRequested="MainTabView_TabCloseRequested"
                              CanDragTabs="True"
                              CanReorderTabs="True"
                              AddTabButtonClick="MainTabView_AddTabButtonClick"
                              Visibility="{x:Bind ViewModel.SearchResults.Count, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}, ConverterParameter='zero'}">

                <controls:TabView.TabItemTemplate>
                    <DataTemplate x:DataType="vm:TabViewModel">
                        <Grid ColumnSpacing="8" Padding="4,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind Title, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       MaxWidth="200"
                                       TextTrimming="CharacterEllipsis" />

                            <ToggleButton Grid.Column="1"
                                          Width="24" Height="24"
                                          Padding="0"
                                          IsChecked="{x:Bind IsSplitMode, Mode=TwoWay}"
                                          ToolTipService.ToolTip="Attiva/Disattiva split (Ctrl+S)"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <SymbolIcon Symbol="Split" />
                            </ToggleButton>

                            <Button Grid.Column="2"
                                    Content="×"
                                    FontSize="10"
                                    Width="20" Height="20"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding DataContext.CloseTabCommand, ElementName=MainTabView, Mode=OneWay}"
                                    CommandParameter="{x:Bind}"
                                    ToolTipService.ToolTip="Chiudi scheda (Ctrl+W)" />
                        </Grid>
                    </DataTemplate>
                </controls:TabView.TabItemTemplate>

                <controls:TabView.TabStripFooter>
                    <TextBlock Text="WinUI 3 + MVVM Toolkit + Split + Search + Cloud + Plugins"
                               FontSize="10"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               Margin="8,0" />
                </controls:TabView.TabStripFooter>

                <controls:TabView.TabContentTemplate>
                    <DataTemplate x:DataType="vm:TabViewModel">
                        <v:TabView />
                    </DataTemplate>
                </controls:TabView.TabContentTemplate>

            </controls:TabView>

            <!-- Risultati della ricerca -->
            <Border Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                    IsVisible="{x:Bind ViewModel.SearchResults.Count, Mode=OneWay, Converter={StaticResource IntToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header risultati -->
                    <Border Grid.Row="0"
                            Background="{ThemeResource SystemControlBackgroundAltMediumLowBrush}"
                            Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Find" />
                            <TextBlock Text="Risultati della ricerca" FontWeight="Bold" />
                            <TextBlock Text="{x:Bind ViewModel.SearchText, Mode=OneWay, StringFormat='(\"{0}\")'}" />
                            <TextBlock Text="|" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.SearchResults.Count, Mode=OneWay, StringFormat='{}Trovati: {0} file'}" />
                        </StackPanel>
                    </Border>

                    <!-- Lista risultati con virtualizzazione -->
                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}"
                              SelectionMode="None">
                        <ListView.ItemContainerTransitions>
                            <TransitionCollection>
                                <AddDeleteThemeTransition />
                            </TransitionCollection>
                        </ListView.ItemContainerTransitions>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:FileItem">
                                <Grid Padding="8,4" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{x:Bind Icon}" FontSize="16" VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Name}"
                                               VerticalAlignment="Center"
                                               FontWeight="{x:Bind IsDirectory, Converter={StaticResource BoolToFontWeightConverter}}"
                                               TextTrimming="CharacterEllipsis" />

                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Size, Converter={StaticResource BytesToStringConverter}}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Width="100"
                                               Visibility="{x:Bind IsDirectory, Converter={StaticResource InverseBoolConverter}}" />

                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind LastModified, Converter={StaticResource DateTimeToStringConverter}}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>